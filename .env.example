# Copy this file to .env and adjust values as needed.
# `make up` / `docker compose up` reads this file for all three services.

# ---- Postgres ----
POSTGRES_DB=auction_db
POSTGRES_USER=auction_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
# Used to build media (card image) URLs. next/image always re-fetches
# images server-side from inside the frontend container, so this must be
# the Docker-internal backend address (matches INTERNAL_API_URL below),
# NOT the browser-facing one.
MEDIA_BASE_URL=http://backend:8000

# ---- JWT (stored in httpOnly cookies) ----
JWT_SIGNING_KEY=change-me-too-can-be-same-as-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
# Set to 1 once served over HTTPS
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax

# ---- Frontend ----
# Browser-facing URL (used by client components, runs on your host machine).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side URL used by Next.js server/edge code running *inside* the
# frontend container, where "localhost" would mean the container itself.
INTERNAL_API_URL=http://backend:8000
